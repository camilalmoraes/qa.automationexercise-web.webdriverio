{
  "name": "qa.automationexercise-web.webdriverio",
  "version": "1.0.0",
  "description": "Automação de testes E2E para o site automationexercise.com utilizando WebdriverIO",
  "type": "module",
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@wdio/allure-reporter": "^9.27.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "allure-commandline": "^2.38.1",
    "cross-env": "^10.1.0"
  },
  "scripts": {
    "wdio": "wdio run ./wdio.conf.js",
    "wdio:headless": "cross-env HEADLESS=true wdio run ./wdio.conf.js",
    "wdio:registro": "wdio run ./wdio.conf.js --suite registro",
    "wdio:registro:headless": "cross-env HEADLESS=true wdio run ./wdio.conf.js --suite registro",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:report": "npm run allure:generate && npm run allure:open"
  }
}
